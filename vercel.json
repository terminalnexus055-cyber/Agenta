{
  "version": 2,
  "functions": {
    "api/run-task.js": {
      "runtime": "nodejs20.x",
      "maxDuration": 60
    },
    "api/summarize.js": {
      "runtime": "nodejs20.x",
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
